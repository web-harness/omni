{
  "name": "omni",
  "version": "1.0.0",
  "description": "Omni is a harness that stays out of your way, compatible with LangGraph Agent Protocol.",
  "main": "index.js",
  "scripts": {
    "start": "cd omni && dx serve",
    "format:biome": "biome format --write",
    "format:cargo": "cargo fmt",
    "format": "npm-run-all --parallel format:*",
    "build:dx": "cd omni && dx bundle --out-dir=../dist --release",
    "build": "npm-run-all build:*",
    "wc:dev": "cd omni-wc && npm run dev",
    "wc:build": "cd omni-wc && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-harness/omni.git"
  },
  "keywords": [],
  "author": "Sepehr Laal",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/web-harness/omni/issues"
  },
  "homepage": "https://github.com/web-harness/omni#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "zx": "^8.8.5"
  }
}
