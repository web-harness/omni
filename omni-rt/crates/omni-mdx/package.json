{
  "name": "@omni/omni-mdx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/omni-mdx.js",
  "module": "dist/omni-mdx.js",
  "scripts": {
    "build": "esbuild src/omni-mdx.tsx --bundle --format=esm --outfile=dist/omni-mdx.js --loader:.css=text --jsx=automatic --jsx-import-source=react",
    "watch": "esbuild src/omni-mdx.tsx --bundle --format=esm --outfile=dist/omni-mdx.js --loader:.css=text --jsx=automatic --jsx-import-source=react --watch"
  },
  "dependencies": {
    "@mdxeditor/editor": "^3.20.0",
    "lit": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.25.2"
  }
}
