{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  }
}
