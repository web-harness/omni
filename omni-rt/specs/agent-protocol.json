{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent Protocol",
    "version": "0.1.6"
  },
  "tags": [
    {
      "name": "Runs",
      "description": "A run is an invocation of an agent, optionally, on a thread. If applied to a thread, it updates the state of the thread. Otherwise, it has not state or memory persistence."
    },
    {
      "name": "Threads",
      "description": "A thread contains the accumulated outputs of a group of runs."
    },
    {
      "name": "Agents",
      "description": "An agent is an LLM-powered actor that can be invoked on a thread."
    }
  ],
  "paths": {},
  "components": {
    "schemas": {
      "Agent": {
        "type": "object",
        "properties": {
          "agent_id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "metadata": {"type": "object"},
          "capabilities": {"type": "object"}
        },
        "required": ["agent_id", "name", "capabilities"]
      },
      "AgentSchema": {
        "type": "object",
        "properties": {
          "agent_id": {"type": "string"},
          "input_schema": {"type": "object"},
          "output_schema": {"type": "object"},
          "state_schema": {"type": "object"},
          "config_schema": {"type": "object"}
        },
        "required": ["agent_id", "input_schema", "output_schema"]
      },
      "RunStatus": {
        "type": "string",
        "enum": ["pending", "error", "success", "timeout", "interrupted"]
      },
      "StreamMode": {
        "type": "string",
        "enum": ["values", "messages", "updates", "custom"]
      },
      "Run": {
        "type": "object",
        "properties": {
          "run_id": {"type": "string", "format": "uuid"},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"},
          "status": {"$ref": "#/components/schemas/RunStatus"},
          "metadata": {"type": "object"},
          "thread_id": {"type": "string", "format": "uuid"},
          "agent_id": {"type": "string"}
        },
        "required": ["run_id", "created_at", "updated_at", "status", "metadata"]
      },
      "RunCreate": {
        "type": "object",
        "properties": {
          "thread_id": {"type": "string", "format": "uuid"},
          "agent_id": {"type": "string"},
          "input": {},
          "messages": {"type": "array", "items": {"$ref": "#/components/schemas/Message"}},
          "metadata": {"type": "object"},
          "config": {"type": "object"},
          "webhook": {"type": "string"},
          "on_completion": {"type": "string", "enum": ["delete", "keep"]},
          "on_disconnect": {"type": "string", "enum": ["cancel", "continue"]},
          "if_not_exists": {"type": "string", "enum": ["create", "reject"]}
        }
      },
      "RunStream": {
        "allOf": [
          {"$ref": "#/components/schemas/RunCreate"},
          {
            "type": "object",
            "properties": {
              "stream_mode": {"anyOf": [{"$ref": "#/components/schemas/StreamMode"}, {"type": "array", "items": {"$ref": "#/components/schemas/StreamMode"}}]}
            }
          }
        ]
      },
      "RunWaitResponse": {
        "type": "object",
        "properties": {
          "run": {"$ref": "#/components/schemas/Run"},
          "values": {"type": "object"},
          "messages": {"type": "array", "items": {"$ref": "#/components/schemas/Message"}}
        }
      },
      "RunSearchRequest": {
        "type": "object",
        "properties": {
          "metadata": {"type": "object"},
          "status": {"$ref": "#/components/schemas/RunStatus"},
          "thread_id": {"type": "string", "format": "uuid"},
          "agent_id": {"type": "string"},
          "limit": {"type": "integer", "default": 10},
          "offset": {"type": "integer", "default": 0}
        }
      },
      "ThreadStatus": {
        "type": "string",
        "enum": ["idle", "busy", "interrupted", "error"]
      },
      "TableCheckpoint": {
        "type": "object",
        "properties": {
          "checkpoint_id": {"type": "string", "format": "uuid"}
        },
        "required": ["checkpoint_id"],
        "additionalProperties": true
      },
      "ThreadState": {
        "type": "object",
        "properties": {
          "checkpoint": {"$ref": "#/components/schemas/TableCheckpoint"},
          "values": {"type": "object"},
          "messages": {"type": "array", "items": {"$ref": "#/components/schemas/Message"}},
          "metadata": {"type": "object"}
        },
        "required": ["checkpoint", "values"]
      },
      "Thread": {
        "type": "object",
        "properties": {
          "thread_id": {"type": "string", "format": "uuid"},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"},
          "metadata": {"type": "object"},
          "status": {"$ref": "#/components/schemas/ThreadStatus"},
          "values": {"type": "object"},
          "messages": {"type": "array", "items": {"$ref": "#/components/schemas/Message"}}
        },
        "required": ["thread_id", "created_at", "updated_at", "metadata", "status"]
      },
      "ThreadCreate": {
        "type": "object",
        "properties": {
          "thread_id": {"type": "string", "format": "uuid"},
          "metadata": {"type": "object"},
          "if_exists": {"type": "string", "enum": ["raise", "do_nothing"], "default": "raise"}
        }
      },
      "ThreadPatch": {
        "type": "object",
        "properties": {
          "checkpoint": {"$ref": "#/components/schemas/TableCheckpoint"},
          "metadata": {"type": "object"},
          "values": {"type": "object"},
          "messages": {"type": "array", "items": {"$ref": "#/components/schemas/Message"}}
        }
      },
      "ThreadSearchRequest": {
        "type": "object",
        "properties": {
          "metadata": {"type": "object"},
          "values": {"type": "object"},
          "status": {"$ref": "#/components/schemas/ThreadStatus"},
          "limit": {"type": "integer", "default": 10},
          "offset": {"type": "integer", "default": 0}
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "role": {"type": "string"},
          "content": {},
          "id": {"type": "string"},
          "metadata": {"type": "object", "additionalProperties": true}
        },
        "required": ["role", "content"],
        "additionalProperties": true
      },
      "StorePutRequest": {
        "type": "object",
        "properties": {
          "namespace": {"type": "array", "items": {"type": "string"}},
          "key": {"type": "string"},
          "value": {"type": "object"}
        },
        "required": ["namespace", "key", "value"]
      },
      "StoreDeleteRequest": {
        "type": "object",
        "properties": {
          "namespace": {"type": "array", "items": {"type": "string"}},
          "key": {"type": "string"}
        },
        "required": ["key"]
      },
      "StoreSearchRequest": {
        "type": "object",
        "properties": {
          "namespace_prefix": {"type": ["array", "null"], "items": {"type": "string"}},
          "filter": {"type": ["object", "null"]},
          "limit": {"type": "integer", "default": 10},
          "offset": {"type": "integer", "default": 0}
        }
      },
      "StoreListNamespacesRequest": {
        "type": "object",
        "properties": {
          "prefix": {"type": "array", "items": {"type": "string"}},
          "suffix": {"type": "array", "items": {"type": "string"}},
          "max_depth": {"type": "integer"},
          "limit": {"type": "integer", "default": 100},
          "offset": {"type": "integer", "default": 0}
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "namespace": {"type": "array", "items": {"type": "string"}},
          "key": {"type": "string"},
          "value": {"type": "object"},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"}
        },
        "required": ["namespace", "key", "value", "created_at", "updated_at"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"},
          "metadata": {"type": "object"}
        }
      }
    }
  }
}
